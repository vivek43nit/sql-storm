{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "FkBlitz operational dashboard — queries, CRUD, auth, connections",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }, "unit": "reqps" }
      },
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{ "expr": "sum(rate(fkblitz_query_requests_total{status=\"success\"}[5m]))", "legendFormat": "Query Rate" }],
      "title": "Query Rate (success/s)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] }, "unit": "reqps" }
      },
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{ "expr": "sum(rate(fkblitz_query_requests_total{status=\"error\"}[5m]))", "legendFormat": "Error Rate" }],
      "title": "Query Error Rate (/s)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "red", "value": 1 }] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 10, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{ "expr": "fkblitz_connections_active", "legendFormat": "Active" }],
      "title": "Active DB Connections",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "orange", "value": 5 }, { "color": "red", "value": 20 }] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{ "expr": "increase(fkblitz_auth_failures_total[1h])", "legendFormat": "Failures (1h)" }],
      "title": "Auth Failures (last 1h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Query Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (group, database) (rate(fkblitz_query_requests_total{status=\"success\"}[1m]))", "legendFormat": "{{group}}/{{database}} ok" },
        { "expr": "sum by (group, database) (rate(fkblitz_query_requests_total{status=\"error\"}[1m]))", "legendFormat": "{{group}}/{{database}} err" }
      ],
      "title": "Query Rate by DB",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 }, "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le, group, database) (rate(fkblitz_query_duration_seconds_bucket[5m]))) * 1000", "legendFormat": "p50 {{group}}/{{database}}" },
        { "expr": "histogram_quantile(0.95, sum by (le, group, database) (rate(fkblitz_query_duration_seconds_bucket[5m]))) * 1000", "legendFormat": "p95 {{group}}/{{database}}" },
        { "expr": "histogram_quantile(0.99, sum by (le, group, database) (rate(fkblitz_query_duration_seconds_bucket[5m]))) * 1000", "legendFormat": "p99 {{group}}/{{database}}" }
      ],
      "title": "Query Latency (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "CRUD & Auth",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 60 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (operation) (rate(fkblitz_crud_operations_total[5m]))", "legendFormat": "{{operation}}" }
      ],
      "title": "CRUD Operations Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 60 }, "unit": "short", "color": { "fixedColor": "red", "mode": "fixed" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "expr": "increase(fkblitz_auth_failures_total[5m])", "legendFormat": "Auth Failures" }
      ],
      "title": "Auth Failures",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["fkblitz", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FkBlitz",
  "uid": "fkblitz-main",
  "version": 1
}
